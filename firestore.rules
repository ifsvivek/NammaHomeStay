rules_version = '2';

// Namma HomeStay — Firestore security rules.
// Deploy with:  firebase deploy --only firestore:rules
// (or paste this into Firebase console → Firestore Database → Rules)
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // A host's own profile.
    match /hosts/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // The "digital shopfront". The host owns it; any signed-in user may read it
    // (so the future traveller-facing app can browse LIVE homestays).
    match /homestays/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // Today's menu — one doc per host, id == host uid.
    match /daily_menus/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // Incoming interests. The host reads / updates ones addressed to them.
    // Any signed-in user may create one (the traveller app will do this; the
    // "add sample interest" test button also relies on this).
    match /inquiries/{inquiryId} {
      allow read, update, delete: if signedIn() && resource.data.hostId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.hostId is string;
    }
  }
}
