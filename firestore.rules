rules_version = '2';

// Namma HomeStay — Firestore security rules.
// Deploy with:  firebase deploy --only firestore:rules
// (or paste this into Firebase console → Firestore Database → Rules)
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // A host's own profile (verifiedStatus is mirrored here).
    match /hosts/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // The "digital shopfront". Owner writes. Any signed-in user can read so the
    // traveller side can browse LIVE homestays and open detail screens.
    match /homestays/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // Today's menu — one doc per host, id == host uid.
    match /daily_menus/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // Inquiries: a traveller sends one to a host. Both sides can read their own
    // half of the conversation, only the host can update / delete (mark called).
    match /inquiries/{inquiryId} {
      // Host reads inquiries addressed to them; traveller reads ones they sent.
      allow read: if signedIn() && (
        resource.data.hostId == request.auth.uid ||
        resource.data.travellerId == request.auth.uid
      );
      // Only the host (the one being inquired about) can change status.
      allow update, delete: if signedIn() && resource.data.hostId == request.auth.uid;
      // Anyone signed-in can create. If they're a traveller the travellerId must
      // be their own uid; the host-side "Add sample interest" button passes an
      // empty travellerId and that's allowed too.
      allow create: if signedIn()
        && request.resource.data.hostId is string
        && (
          request.resource.data.travellerId == ""
          || request.resource.data.travellerId == request.auth.uid
        );
    }

    // Reviews: any signed-in user can read; only the author can create / edit
    // their own; the rating must be a 1–5 integer.
    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.travellerId == request.auth.uid
        && request.resource.data.homestayId is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if signedIn()
        && resource.data.travellerId == request.auth.uid;
    }
  }
}
